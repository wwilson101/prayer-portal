# Prayer Portal — Environment Variables
# Copy this file to .env.local and fill in your Supabase project values.
# In Bolt.new, add these in the Environment Variables panel.

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_ONESIGNAL_APP_ID=your-onesignal-app-id-here
VITE_SUPPORT_EMAIL=support@yourdomain.com
